# Runtime data — regenerated by seed.py on first run, never committed
backend/data/*.db
backend/data/*.db-wal
backend/data/*.db-shm
backend/data/secret.key

# Python
__pycache__/
*.pyc
.venv/

# Original upload archives — content already extracted into the repo
/files.zip
/zip.zip

# Scratch extraction leftover from initial setup
/_extracted/

# Local preview-tooling config (renamed to .devserver/ for the committed
# version) — recreated here transiently as .claude/ when tooling needs it
/.claude/

# OS cruft
.DS_Store
Thumbs.db

# Xcode (once ios-starter gets a real project)
ios-starter/**/xcuserdata/
ios-starter/**/*.xcworkspace/xcuserdata/
ios-starter/**/DerivedData/

# Android/Gradle (once android-starter gets real build tooling)
android-starter/.gradle/
android-starter/build/
android-starter/**/build/
android-starter/local.properties
